rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function ownsExam(examId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/exams/$(examId)).data.createdBy == request.auth.uid;
    }

    function isValidScannedResult(data) {
      let examNumItems = get(/databases/$(database)/documents/exams/$(data.examId)).data.num_items;
      let effectiveMax = data.keys().hasAll(['maxScore']) ? data.maxScore : data.totalQuestions;
      return data.keys().hasAll(['examId', 'studentId', 'score', 'totalQuestions', 'scannedBy'])
          && data.examId is string
          && data.examId.size() > 0
          && data.studentId is string
          && data.score is number
          && data.score >= 0
          && data.totalQuestions is number
          && data.totalQuestions > 0
          && data.totalQuestions <= examNumItems
          && data.score <= effectiveMax;
    }

    function isValidGradeEntry(data) {
      return data.keys().hasAll(['student_id', 'exam_id', 'class_id', 'score', 'max_score', 'percentage'])
          && data.exam_id is string
          && data.exam_id.size() > 0
          && data.student_id is string
          && data.student_id.size() > 0
          && data.class_id is string
          && data.class_id.size() > 0
          && data.score is number
          && data.score >= 0
          && data.max_score is number
          && data.max_score > 0
          && data.percentage is number
          && data.percentage >= 0
          && data.percentage <= 100
          && get(/databases/$(database)/documents/exams/$(data.exam_id)).data.num_items >= data.score
          && get(/databases/$(database)/documents/exams/$(data.exam_id)).data.num_items == data.max_score;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    match /instructors/{instructorId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /metadata/{document} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.instructorId == request.auth.uid
      );
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && 
        (resource.data.createdBy == request.auth.uid || 
         resource.data.userId == request.auth.uid ||
         resource.data.instructorId == request.auth.uid);
    }

    match /answerKeys/{answerKeyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn() && 
                       (resource.data.createdBy == request.auth.uid || 
                        ownsExam(resource.data.examId));
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn() && 
                       (resource.data.createdBy == request.auth.uid || 
                        ownsExam(resource.data.examId));
    }

    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /scannedResults/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidScannedResult(request.resource.data);
      allow update: if isSignedIn()
                       && resource.data.scannedBy == request.auth.uid
                       && isValidScannedResult(request.resource.data);
      allow delete: if isSignedIn() && resource.data.scannedBy == request.auth.uid;
    }

    match /studentGrades/{gradeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGradeEntry(request.resource.data);
      allow update: if isSignedIn() && isValidGradeEntry(request.resource.data)
                       && resource.data.graded_by == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.graded_by == request.auth.uid;
    }

    match /nullIdAlerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /studentAttendance/{attendanceId} {
      allow read, write: if isSignedIn();
    }

    match /studentEnrollments/{enrollmentId} {
      allow read, write: if isSignedIn();
    }

    match /studentExamResults/{resultId} {
      allow read, write: if isSignedIn();
    }

    match /reportHistory/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /examBatches/{batchId} {
      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /scanSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /offlineQueue/{queueId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /syncStatus/{statusId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /storageUsage/{usageId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /invalidRecordLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /studentRosters/{rosterId} {
      allow read, write: if isSignedIn();
    }

    match /import_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /validation_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /instructorSettings/{settingsId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /duplicateScoreOverrides/{overrideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}